---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="About" description="About Njox, developer building tech products in East Africa.">
  <Header />

  <main class="pt-28 pb-16 px-6">
    <div class="max-w-2xl mx-auto">

      <h1 class="font-serif text-3xl text-ink-900 dark:text-ink-50 mb-8">About</h1>

      <div class="prose prose-ink dark:prose-invert prose-sm sm:prose-base max-w-none">
        <p>
          I'm a Full Stack Engineer based in Zanzibar, Tanzania, focused on building real products for real people, not just demos. From event ticketing platforms processing millions in transactions, to real estate web presences for island brands, I care about what ships.
        </p>
        <p>
          I write about what I learn here, covering SaaS, AI, development, and building for East African markets.
        </p>
        <p>
          If you have a problem worth solving, reach out via <a href="mailto:godblessnyagawa@gmail.com">email</a> or <a href="https://www.linkedin.com/in/godbless-nyagawa/" target="_blank" rel="noopener noreferrer">LinkedIn</a>.
        </p>
      </div>

      <div class="mt-10 pt-8 border-t border-ink-100 dark:border-ink-800">
        <p class="text-sm text-ink-400 dark:text-ink-500 mb-4">Looking to hire? Grab my CV.</p>
        <a
          href="/GODBLESS_NYAGAWA_CV.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-ink-200 dark:border-ink-700 text-ink-700 dark:text-ink-300 text-sm font-medium hover:border-accent hover:text-accent dark:hover:border-accent dark:hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
          Download CV
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Base>
