---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="404" description="Page not found.">
  <Header />

  <main class="pt-28 pb-16 px-6 min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto text-center">

      <p class="font-mono text-accent text-sm tracking-widest uppercase mb-4">404</p>
      <h1 class="font-serif text-4xl sm:text-5xl text-ink-900 dark:text-ink-50 mb-4">
        Page not found
      </h1>
      <p class="text-ink-500 dark:text-ink-400 mb-10 text-lg">
        This page does not exist or was moved.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-accent text-white font-medium hover:bg-accent/90 transition-colors">
          Go home
        </a>
        <a href="/about"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full border border-ink-200 dark:border-ink-700 text-ink-700 dark:text-ink-300 font-medium hover:border-ink-400 dark:hover:border-ink-500 transition-colors">
          About Me
        </a>
      </div>

      <!-- CV Download -->
      <div class="mt-16 pt-10 border-t border-ink-100 dark:border-ink-800">
        <p class="text-sm text-ink-400 dark:text-ink-500 mb-4">While you're here, feel free to grab my CV.</p>
        <a
          href="/GODBLESS_NYAGAWA_CV.pdf"
          download
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-ink-200 dark:border-ink-700 text-ink-700 dark:text-ink-300 text-sm font-medium hover:border-accent hover:text-accent dark:hover:border-accent dark:hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
          Download CV
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Base>
