---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Sponsored Posts',
    price: 'From $150',
    description:
      'I write an honest, in-depth post about your product — in my voice, for my audience. Readers are East Africa-focused developers, founders, and SaaS builders.',
    details: [
      'One dedicated post (~800–1500 words)',
      'Permanent — no takedowns after 30 days',
      'Shared to newsletter subscribers',
      'Full editorial control stays with me',
    ],
  },
  {
    title: 'Consulting',
    price: 'Let\'s talk',
    description:
      'I help startups and teams build software for East African markets — from product decisions and technical architecture to SMS/USSD integrations and mobile money.',
    details: [
      'Product strategy for emerging markets',
      'Technical architecture & code review',
      'SMS, USSD, M-Pesa/mobile money integrations',
      'Short engagements or ongoing retainer',
    ],
  },
  {
    title: 'Newsletter Sponsorship',
    price: 'From $80',
    description:
      'One placement in my newsletter — seen by subscribers who are actively building products in East Africa and beyond.',
    details: [
      'Text-based, no banner ads',
      'One sponsor per issue',
      'Includes a short description you write',
      'Audience: developers, founders, tech builders',
    ],
  },
];
---

<Base
  title="Work With Me"
  description="Sponsored posts, consulting, and newsletter sponsorships for East Africa-focused tech brands."
>
  <Header />

  <main class="pt-28 pb-16 px-6">
    <div class="max-w-2xl mx-auto">

      <!-- Intro -->
      <section class="mb-14">
        <h1 class="font-serif text-3xl text-ink-900 dark:text-ink-50 mb-4">
          Work with me
        </h1>
        <p class="text-base text-ink-500 dark:text-ink-400 leading-relaxed max-w-lg">
          I write for developers and founders building in East Africa. If your product is relevant to that
          audience, I'd love to work together.
        </p>
      </section>

      <!-- Services -->
      <section class="space-y-6 mb-16">
        {services.map(service => (
          <div class="p-6 rounded-xl border border-ink-100 dark:border-ink-800/60">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h2 class="font-serif text-xl text-ink-900 dark:text-ink-50">{service.title}</h2>
              <span class="shrink-0 text-sm font-medium text-accent">{service.price}</span>
            </div>
            <p class="text-sm text-ink-500 dark:text-ink-400 leading-relaxed mb-4">
              {service.description}
            </p>
            <ul class="space-y-1.5">
              {service.details.map(d => (
                <li class="flex items-start gap-2 text-sm text-ink-600 dark:text-ink-400">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <!-- Contact -->
      <section class="pt-10 border-t border-ink-100 dark:border-ink-800/60">
        <h2 class="font-serif text-xl text-ink-900 dark:text-ink-50 mb-3">Get in touch</h2>
        <p class="text-sm text-ink-500 dark:text-ink-400 leading-relaxed mb-6">
          Send me a short note about what you have in mind — the product, the goal,
          and roughly when you need it. I reply within 2 business days.
        </p>
        <a
          href="mailto:hello@njox.dev"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg
                 bg-ink-900 dark:bg-ink-50 text-ink-50 dark:text-ink-900
                 text-sm font-medium
                 hover:bg-accent dark:hover:bg-accent hover:text-white dark:hover:text-white
                 transition-colors duration-150"
        >
          hello@njox.dev
          <span>→</span>
        </a>
      </section>

    </div>
  </main>

  <Footer />
</Base>
