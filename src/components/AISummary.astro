---
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<div
  id="ai-summary"
  data-slug={slug}
  class="my-10 rounded-xl border border-ink-100 dark:border-ink-800/60 overflow-hidden"
>
  <!-- Header row -->
  <div class="flex items-center justify-between gap-4 px-5 py-4">
    <div class="flex items-center gap-2">
      <!-- Sparkle icon -->
      <svg class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l1.8 5.4L19.2 9l-5.4 1.8L12 16.2l-1.8-5.4L4.8 9l5.4-1.8L12 2z"/>
        <path d="M5 17l.9 2.7L8.6 21l-2.7.9L5 24.6l-.9-2.7L1.4 21l2.7-.9L5 17z" opacity="0.5"/>
        <path d="M19 3l.6 1.8 1.8.6-1.8.6L19 8l-.6-1.8L16.6 5.4l1.8-.6L19 3z" opacity="0.5"/>
      </svg>
      <span class="text-sm font-medium text-ink-700 dark:text-ink-300">AI Summary</span>
    </div>

    <button
      id="summary-btn"
      class="text-xs px-3 py-1.5 rounded-md bg-accent text-white font-medium
             hover:opacity-90 transition-opacity duration-150 shrink-0"
    >
      Generate
    </button>
  </div>

  <!-- Content area (hidden until generated) -->
  <div id="summary-body" class="hidden px-5 pb-5">
    <!-- Loading skeleton -->
    <div id="summary-loading" class="hidden space-y-2.5">
      {[80, 65, 72, 55].map(w => (
        <div class="flex items-start gap-2.5">
          <div class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ink-200 dark:bg-ink-700 shrink-0"></div>
          <div class="h-3 rounded bg-ink-100 dark:bg-ink-800 animate-pulse" style={`width:${w}%`}></div>
        </div>
      ))}
    </div>

    <!-- Bullets -->
    <ul id="summary-bullets" class="hidden space-y-2.5 list-none p-0 m-0"></ul>

    <!-- Error -->
    <p id="summary-error" class="hidden text-sm text-red-500 dark:text-red-400"></p>

    <!-- Footer -->
    <div id="summary-footer" class="hidden mt-4 pt-3 border-t border-ink-100 dark:border-ink-800/60 flex items-center gap-1.5">
      <svg class="w-3 h-3 text-ink-300 dark:text-ink-600" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l1.8 5.4L19.2 9l-5.4 1.8L12 16.2l-1.8-5.4L4.8 9l5.4-1.8L12 2z"/>
      </svg>
      <span class="text-xs text-ink-300 dark:text-ink-600">Generated by Claude</span>
    </div>
  </div>
</div>

<script>
  function init() {
    const root    = document.getElementById('ai-summary');
    const btn     = document.getElementById('summary-btn');
    const body    = document.getElementById('summary-body');
    const loading = document.getElementById('summary-loading');
    const bullets = document.getElementById('summary-bullets');
    const error   = document.getElementById('summary-error');
    const footer  = document.getElementById('summary-footer');

    if (!root || !btn) return;

    const slug = root.dataset.slug ?? '';
    let generated = false;

    btn.addEventListener('click', async () => {
      if (generated) {
        // Toggle visibility
        const isHidden = body!.classList.contains('hidden');
        body!.classList.toggle('hidden', !isHidden);
        btn.textContent = isHidden ? 'Hide' : 'Show';
        return;
      }

      // Show loading state
      btn.textContent = 'Generating…';
      btn.setAttribute('disabled', '');
      body!.classList.remove('hidden');
      loading!.classList.remove('hidden');

      try {
        const res = await fetch('/api/summarize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });

        const data = await res.json();

        loading!.classList.add('hidden');

        if (!res.ok || data.error) {
          error!.textContent = data.error ?? 'Something went wrong.';
          error!.classList.remove('hidden');
          btn.textContent = 'Retry';
          btn.removeAttribute('disabled');
          return;
        }

        // Parse bullets — each line starting with •, -, or *
        const lines: string[] = data.summary
          .split('\n')
          .map((l: string) => l.replace(/^[•\-\*]\s*/, '').trim())
          .filter((l: string) => l.length > 0);

        bullets!.innerHTML = lines.map(l => `
          <li class="flex items-start gap-2.5 text-sm text-ink-600 dark:text-ink-400 leading-relaxed">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
            <span>${l}</span>
          </li>
        `).join('');

        bullets!.classList.remove('hidden');
        footer!.classList.remove('hidden');
        btn.textContent = 'Hide';
        btn.removeAttribute('disabled');
        generated = true;
      } catch {
        loading!.classList.add('hidden');
        error!.textContent = 'Network error. Please try again.';
        error!.classList.remove('hidden');
        btn.textContent = 'Retry';
        btn.removeAttribute('disabled');
      }
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
