---
const navLinks = [
  { href: '/', label: 'Writing' },
  { href: '/tags', label: 'Tags' },
  { href: '/about', label: 'About' },
  { href: '/search', label: 'Search' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-50 bg-ink-50/80 dark:bg-ink-950/80 backdrop-blur-md border-b border-ink-100 dark:border-ink-800/60">
  <nav class="max-w-2xl mx-auto px-6 h-14 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-serif text-lg text-ink-900 dark:text-ink-50 hover:text-accent transition-colors duration-150">
      njox
    </a>

    <!-- Desktop links -->
    <div class="hidden sm:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors duration-150',
            currentPath === link.href
              ? 'text-ink-900 dark:text-ink-50 font-medium'
              : 'text-ink-400 dark:text-ink-500 hover:text-ink-700 dark:hover:text-ink-300'
          ]}
        >
          {link.label}
        </a>
      ))}

      <a
        href="/work-with-me"
        class="text-sm font-medium px-3 py-1 rounded-md bg-accent text-white hover:opacity-90 transition-opacity duration-150"
      >
        Hire me
      </a>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="w-8 h-8 flex items-center justify-center rounded-md text-ink-400 dark:text-ink-500 hover:text-ink-700 dark:hover:text-ink-200 hover:bg-ink-100 dark:hover:bg-ink-800 transition-all duration-150"
      >
        <svg id="icon-sun" class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8.66-9H21M3 12H2m15.07 6.07-.71-.71M6.64 6.64l-.71-.71M17.66 6.64l.71-.71M7.05 17.07l-.71.71M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
        </svg>
        <svg id="icon-moon" class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0112 21.75 9.75 9.75 0 1118 3.278a7.5 7.5 0 003.752 11.724z"/>
        </svg>
      </button>
    </div>

    <!-- Mobile: dark toggle + hamburger -->
    <div class="flex sm:hidden items-center gap-2">
      <button
        id="theme-toggle-mobile"
        aria-label="Toggle dark mode"
        class="w-8 h-8 flex items-center justify-center rounded-md text-ink-400 dark:text-ink-500 hover:bg-ink-100 dark:hover:bg-ink-800 transition-all duration-150"
      >
        <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m8.66-9H21M3 12H2m15.07 6.07-.71-.71M6.64 6.64l-.71-.71M17.66 6.64l.71-.71M7.05 17.07l-.71.71M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
        </svg>
        <svg class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0112 21.75 9.75 9.75 0 1118 3.278a7.5 7.5 0 003.752 11.724z"/>
        </svg>
      </button>

      <button
        id="menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        class="w-8 h-8 flex items-center justify-center rounded-md text-ink-400 dark:text-ink-500 hover:bg-ink-100 dark:hover:bg-ink-800 transition-all duration-150"
      >
        <!-- Hamburger -->
        <svg id="icon-menu" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
        </svg>
        <!-- Close -->
        <svg id="icon-close" class="hidden w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </nav>

  <!-- Mobile menu drawer -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden border-t border-ink-100 dark:border-ink-800/60 bg-ink-50/95 dark:bg-ink-950/95 backdrop-blur-md"
  >
    <div class="max-w-2xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'py-2.5 text-sm transition-colors duration-150',
            currentPath === link.href
              ? 'text-ink-900 dark:text-ink-50 font-medium'
              : 'text-ink-500 dark:text-ink-400'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/work-with-me"
        class="mt-2 py-2.5 px-4 text-sm font-medium text-center rounded-md bg-accent text-white hover:opacity-90 transition-opacity duration-150"
      >
        Hire me
      </a>
    </div>
  </div>
</header>

<script>
  function init() {
    // Desktop dark mode
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Mobile dark mode
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    // Hamburger
    const menuBtn = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    menuBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('hidden') === false;
      menuBtn.setAttribute('aria-expanded', String(isOpen));
      iconMenu?.classList.toggle('hidden', isOpen);
      iconClose?.classList.toggle('hidden', !isOpen);
    });

    // Close menu on link click
    mobileMenu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuBtn?.setAttribute('aria-expanded', 'false');
        iconMenu?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
