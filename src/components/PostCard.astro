---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  cover?: string;
}

const { title, description, date, slug, tags = [], cover } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card group py-7 border-b border-ink-100 dark:border-ink-800/60 last:border-0 opacity-0 translate-y-4 transition-[opacity,transform] duration-500 ease-out">
  <a href={`/blog/${slug}`} class="block">
    {cover && (
      <div class="mb-4 overflow-hidden rounded-lg aspect-[2/1]">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )}
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <h2 class="font-serif text-xl text-ink-900 dark:text-ink-50 group-hover:text-accent transition-colors duration-150 leading-snug mb-2">
          {title}
        </h2>
        <p class="text-sm text-ink-500 dark:text-ink-400 line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
      <span class="shrink-0 mt-1 text-ink-300 dark:text-ink-700 group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-150">
        →
      </span>
    </div>

    <div class="flex items-center gap-3 mt-4">
      <time class="text-xs text-ink-400 dark:text-ink-600" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {tags.length > 0 && (
        <>
          <span class="text-ink-200 dark:text-ink-700">·</span>
          <div class="flex gap-1.5 flex-wrap">
            {tags.slice(0, 3).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </>
      )}
    </div>
  </a>
</article>

<script>
  function initCards() {
    const cards = document.querySelectorAll<HTMLElement>('.post-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.1 }
    );

    cards.forEach((card, i) => {
      card.style.transitionDelay = `${i * 60}ms`;
      observer.observe(card);
    });
  }

  initCards();
  document.addEventListener('astro:page-load', initCards);
</script>
