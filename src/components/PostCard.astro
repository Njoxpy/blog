---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group py-7 border-b border-ink-100 dark:border-ink-800/60 last:border-0">
  <a href={`/blog/${slug}`} class="block">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <h2 class="font-serif text-xl text-ink-900 dark:text-ink-50 group-hover:text-accent transition-colors duration-150 leading-snug mb-2">
          {title}
        </h2>
        <p class="text-sm text-ink-500 dark:text-ink-400 line-clamp-2 leading-relaxed">
          {description}
        </p>
      </div>
      <span class="shrink-0 mt-1 text-ink-300 dark:text-ink-700 group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-150">
        →
      </span>
    </div>

    <div class="flex items-center gap-3 mt-4">
      <time class="text-xs text-ink-400 dark:text-ink-600" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {tags.length > 0 && (
        <>
          <span class="text-ink-200 dark:text-ink-700">·</span>
          <div class="flex gap-1.5 flex-wrap">
            {tags.slice(0, 3).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </>
      )}
    </div>
  </a>
</article>
