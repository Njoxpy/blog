---
interface Post {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

if (!posts.length) return;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

{posts.length > 0 && (
  <aside class="mt-16 pt-10 border-t border-ink-100 dark:border-ink-800/60">
    <h2 class="font-serif text-xl text-ink-900 dark:text-ink-50 mb-6">Related posts</h2>
    <div class="space-y-1">
      {posts.map(post => (
        <a
          href={`/blog/${post.slug}`}
          class="group flex items-start justify-between gap-4 py-4 border-b border-ink-100 dark:border-ink-800/60 last:border-0"
        >
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-ink-800 dark:text-ink-200 group-hover:text-accent transition-colors duration-150 leading-snug mb-1">
              {post.title}
            </p>
            <p class="text-xs text-ink-400 dark:text-ink-600">{formatDate(post.date)}</p>
          </div>
          <span class="shrink-0 text-ink-300 dark:text-ink-700 group-hover:text-accent group-hover:translate-x-0.5 transition-all duration-150 mt-0.5">
            →
          </span>
        </a>
      ))}
    </div>
  </aside>
)}
